# ============================================
# Personal OS Framework .gitignore
# Protect private content from accidental sync
# ============================================

# Private vault: never track or sync
_private/

# Obsidian workspace state: device-specific
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# System files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Temporary files
*.tmp
*.bak
~$*
*.swp
